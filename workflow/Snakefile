import os
import sys
from datetime import datetime

import pandas as pd


configfile: os.path.join(workflow.basedir, "../config/config.yaml")


sys.path.insert(0, os.path.join(workflow.basedir, "../config"))
from const import (
    NONBULK_ASSAYS,
    BULK_ASSAYS,
    ALLOWED_ASSAY_TYPES,
    ALLOWED_REFVERS,
    ASSAY_TYPE2MODALITY,
    ASSAY_TYPE2FEATURE_TYPE,
    get_eagle_gmap_path,
    get_shapeit_gmap_path,
    get_phasing_panel_path,
)

_run_id = datetime.now().strftime("%Y%m%d_%H%M%S")

# Skip validation when no real config is provided (e.g., --conda-create-envs-only).
# Detected by checking that sample_file points to an existing file.
_has_config = (
    "workflow_mode" in config
    and config.get("sample_file") is not None
    and os.path.isfile(config["sample_file"])
)

if _has_config:
    ##################################################
    print("=== Resolved config ===")
    for key, val in config.items():
        print(f"  {key}: {val}")
    print()

    workflow_mode = config["workflow_mode"]
    assert workflow_mode in {
        "bulk_genotyping",
        "single_cell_genotyping",
        "copytyping_preprocess",
    }

    # parse sample file
    sample_df = pd.read_table(config["sample_file"])
    required = ["SAMPLE", "REP_ID", "assay_type", "sample_type", "PATH_to_bam"]
    optional = ["PATH_to_barcodes", "PATH_to_10x_ranger"]
    missing = [c for c in required if c not in sample_df.columns]
    assert not missing, f"missing columns: {missing}"
    for c in optional:
        if c not in sample_df.columns:
            sample_df[c] = pd.NA
    SAMPLE_ID = config["sample_id"]
    sample_df = sample_df.loc[sample_df["SAMPLE"] == SAMPLE_ID].reset_index(drop=True)
    assert len(sample_df) > 0, f"no rows matching sample_id={SAMPLE_ID} in sample file"
    assert sample_df["REP_ID"].notna().all(), "REP_ID required for all replicates"
    assert sample_df["PATH_to_bam"].notna().all(), "PATH_to_bam has missing values"

    # filter to configured assay types
    configured_assay_types = config["assay_types"]
    assert all(
        at in ALLOWED_ASSAY_TYPES for at in configured_assay_types
    ), f"unknown assay_types in config: {configured_assay_types}"
    sample_df = sample_df.loc[
        sample_df["assay_type"].isin(configured_assay_types)
    ].reset_index(drop=True)
    assert (
        len(sample_df) > 0
    ), f"no rows with assay_type in {configured_assay_types} for sample_id={SAMPLE_ID}"

    uniq_sample_types = sample_df["sample_type"].unique().tolist()
    assert all(st in ["normal", "tumor"] for st in uniq_sample_types)
    sample_df["modality"] = sample_df["assay_type"].map(ASSAY_TYPE2MODALITY)

    if workflow_mode == "bulk_genotyping":
        sample_df = sample_df.loc[
            sample_df["assay_type"].isin(BULK_ASSAYS), :
        ].reset_index(drop=True)
        assert len(sample_df) > 0, "no samples for bulk_genotyping mode"
        assert sample_df["assay_type"].nunique() == 1, (
            "bulk_genotyping mode requires all samples to have the same assay_type, "
            f"got: {sample_df['assay_type'].unique().tolist()}"
        )
        assert sample_df["REP_ID"].nunique() == len(
            sample_df
        ), "bulk mode must have no duplicated replicate IDs"
        run_genotype_snps = True
    elif workflow_mode == "single_cell_genotyping":
        sample_df = sample_df.loc[
            sample_df["assay_type"].isin(NONBULK_ASSAYS), :
        ].reset_index(drop=True)
        assert len(sample_df) > 0, "no samples for single_cell_genotyping mode"
        assert (
            sample_df["PATH_to_barcodes"].notna().all()
        ), "PATH_to_barcodes has missing values"
        assert (
            sample_df["PATH_to_10x_ranger"].notna().all()
        ), "PATH_to_10x_ranger has missing values"
        # validate per-replicate records
        for rep_id, rep_df in sample_df.groupby(by="REP_ID", sort=False):
            rep_assay_types = rep_df["assay_type"].unique().tolist()
            assert (
                len(rep_assay_types) <= 2
            ), "at most 2 data types allowed per replicate"
            if len(rep_assay_types) == 2:
                assert ("scRNA" in rep_assay_types) and ("scATAC" in rep_assay_types)
        run_genotype_snps = True
    elif workflow_mode == "copytyping_preprocess":
        sample_df = sample_df.loc[
            sample_df["assay_type"].isin(NONBULK_ASSAYS), :
        ].reset_index(drop=True)
        assert len(sample_df) > 0, "no nonbulk for single_cell_genotyping mode"
        assert config.get("het_snp_vcf") is not None
        assert config.get("bb_file") is not None
        run_genotype_snps = False
    else:
        raise ValueError(f"unknown mode: {workflow_mode}")

    rep_ids = sample_df["REP_ID"].unique().tolist()
    assay_types = sample_df["assay_type"].unique().tolist()
    modalities = sample_df["modality"].unique().tolist()
    normal_bams = sample_df.loc[
        sample_df["sample_type"] == "normal", "PATH_to_bam"
    ].to_list()
    tumor_bams = sample_df.loc[
        sample_df["sample_type"] == "tumor", "PATH_to_bam"
    ].to_list()

    modality2bams = {}
    for modality, rows in sample_df.groupby("modality", sort=False):
        modality2bams[modality] = rows["PATH_to_bam"].tolist()

    assay2rep_ids = {}
    assay2sample_types = {}
    for assay_type, rows in sample_df.groupby("assay_type", sort=False):
        assay2rep_ids[assay_type] = rows["REP_ID"].tolist()
        assay2sample_types[assay_type] = rows["sample_type"].tolist()

    for assay_type in ALLOWED_ASSAY_TYPES:
        if assay_type not in assay2rep_ids:
            assay2rep_ids[assay_type] = []
            assay2sample_types[assay_type] = []

    get_data = {}
    rep2modalities = {}
    rep2isMultiome = {}
    for rep_id, rep_df in sample_df.groupby(by="REP_ID", sort=False):
        rep2modalities[rep_id] = rep_df["modality"].tolist()
        rep2isMultiome[rep_id] = len(rep_df) > 1
        for _, row in rep_df.iterrows():
            assay_type = row["assay_type"]
            get_data[(assay_type, rep_id)] = [
                row["PATH_to_barcodes"],
                row["PATH_to_bam"],
                row["PATH_to_10x_ranger"],
            ]

    if len(rep_ids) > 1 and any(rep2isMultiome.values()):
        print("genotyping >1 replicates involving multiome data, warning")

    ##################################################
    # parse phase_snps inputs
    refvers = config["reference_version"]
    assert refvers in ALLOWED_REFVERS, f"unsupported reference version: {refvers}"

    phaser = config.get("phaser", "undefined")

    # population-based phasing required to estimate switchprobs
    require_genetic_map = run_genotype_snps and phaser not in ["longphase"]
    if run_genotype_snps:
        phaser_dir = config.get("phaser_dir")
        if phaser == "eagle":
            assert phaser_dir is not None, "phaser_dir required for eagle phasing"
            gmap_dir, get_genetic_map = get_eagle_gmap_path(phaser_dir, refvers)
            assert os.path.isdir(gmap_dir), f"failed to locate gmap directory: {gmap_dir}"
        elif phaser == "shapeit":
            assert phaser_dir is not None, "phaser_dir required for shapeit phasing"
            gmap_dir, get_genetic_map = get_shapeit_gmap_path(
                phaser_dir, refvers,
            )
            assert os.path.isdir(gmap_dir), f"failed to locate gmap directory: {gmap_dir}"
        elif phaser == "longphase":
            pass  # no genetic map needed
        else:
            raise ValueError(f"unknown phaser: {phaser}")

        if phaser in ["eagle", "shapeit"]:
            missing_gmaps = [
                get_genetic_map(c) for c in config["chromosomes"]
                if not os.path.exists(get_genetic_map(c))
            ]
            assert not missing_gmaps, f"failed to locate gmap files: {missing_gmaps[:3]}"
            phasing_panel = config["phasing_panel"]
            assert os.path.isdir(phasing_panel), f"failed to locate phasing panel: {phasing_panel}"
            get_phasing_panel = get_phasing_panel_path(phasing_panel)
            missing_panels = [
                get_phasing_panel(c) for c in config["chromosomes"]
                if not os.path.exists(get_phasing_panel(c))
            ]
            assert not missing_panels, f"failed to locate panel files: {missing_panels[:3]}"

    ##################################################
    # final target files

    def _bb_targets(assay_type, suffixes):
        """Generate target paths under bb_dir for a given assay type."""
        return [config["bb_dir"] + f"/{assay_type}/{s}" for s in suffixes]

    final_targets = []
    if workflow_mode == "copytyping_preprocess":
        for assay_type in assay_types:
            final_targets += _bb_targets(
                assay_type,
                [
                    "cnv_segments.tsv",
                    "bb.Xcount.npz",
                    "bb.Tallele.npz",
                    "bb.Aallele.npz",
                    "bb.Ballele.npz",
                ],
            )
    else:
        common_suffixes = [
            "bb.tsv.gz",
            "bb.Tallele.npz",
            "bb.Aallele.npz",
            "bb.Ballele.npz",
        ]
        for assay_type in assay_types:
            final_targets += _bb_targets(
                assay_type, ["sample_ids.tsv"] + common_suffixes
            )
            if assay_type in BULK_ASSAYS:
                final_targets += _bb_targets(
                    assay_type, ["bb.baf.npz", "bb.rdr.npz", "bb.depth.npz"]
                )
            else:
                final_targets.append(
                    config["allele_dir"] + f"/{assay_type}/barcodes.tsv.gz"
                )

    ##################################################
    os.makedirs(config["qc_dir"], exist_ok=True)

    # entrypoint
    include: "rules/common.smk"
    include: "rules/genotype_snps.smk"
    include: "rules/phase_snps.smk"
    include: "rules/pileup_snps.smk"
    include: "rules/process_anndata.smk"
    include: "rules/phase_and_concat.smk"
    include: "rules/count_reads.smk"
    include: "rules/combine_counts.smk"

    if workflow_mode == "copytyping_preprocess":

        ruleorder: cnv_segmentation > combine_counts_nonbulk

    else:

        ruleorder: combine_counts_nonbulk > cnv_segmentation

    rule all:
        input:
            final_targets,
        default_target: True

else:

    # install conda env
    rule _conda_env_base:
        output:
            temp(".conda_env_base"),
        conda:
            "envs/base.yaml"
        shell:
            "touch {output}"

    rule _conda_env_tools:
        output:
            temp(".conda_env_tools"),
        conda:
            "envs/tools.yaml"
        shell:
            "touch {output}"

    rule _conda_env_phase:
        output:
            temp(".conda_env_phase"),
        conda:
            "envs/phase.yaml"
        shell:
            "touch {output}"

    rule _conda_env_snapatac2:
        output:
            temp(".conda_env_snapatac2"),
        conda:
            "envs/snapatac2.yaml"
        shell:
            "touch {output}"

    rule all:
        input:
            ".conda_env_base",
            ".conda_env_tools",
            ".conda_env_phase",
            ".conda_env_snapatac2",
        default_target: True
